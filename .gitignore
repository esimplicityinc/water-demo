# ClawMarket .gitignore
# Comprehensive ignore rules for Next.js, Convex, Bun, and development tools

# ==============================================================================
# Dependencies
# ==============================================================================
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Bun
bun.lockb

# ==============================================================================
# Next.js
# ==============================================================================
.next/
out/
dist/
build/

# Next.js build output
.vercel

# ==============================================================================
# Convex
# ==============================================================================
.convex/
convex/_generated/
.convex-dev/

# ==============================================================================
# Environment Variables
# ==============================================================================
# Keep .env.local.example for documentation
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ==============================================================================
# Testing
# ==============================================================================
coverage/
.nyc_output/
*.lcov

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Vitest
.vitest/

# ==============================================================================
# TypeScript
# ==============================================================================
*.tsbuildinfo
next-env.d.ts

# ==============================================================================
# Logs
# ==============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
lerna-debug.log*

# Logs
logs
*.log

# ==============================================================================
# IDE and Editor Folders
# ==============================================================================

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Cursor
.cursor/

# Claude Code
.claude/

# AI Agents
.agents/

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# JetBrains
.idea/
*.swp
*.swo
*~

# Vim
*.swp
*.swo
*.swn

# Emacs
*~
\#*\#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==============================================================================
# OS Files
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==============================================================================
# Docusaurus
# ==============================================================================
docs/.docusaurus/
docs/build/
docs/.cache/
docs/node_modules/
docs/bun.lockb

# ==============================================================================
# Miscellaneous
# ==============================================================================

# Certificates
*.pem
*.key
*.crt

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Archive files
*.zip
*.tar.gz
*.rar

# Backup files
*.backup
*.bak
*.old

# ==============================================================================
# Project Specific
# ==============================================================================

# Local development overrides
.local/
local/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup

# Docker
.dockerignore

# Database dumps
*.sql
*.sqlite
*.db

# Seeds (if you don't want to commit)
# seeds/

# ==============================================================================
# Security - Never commit these!
# ==============================================================================

# API Keys and Secrets (extra safety)
secrets/
.secrets/
credentials.json
service-account.json

# Private keys
private/
.private/

# ==============================================================================
# Performance and Monitoring
# ==============================================================================

# Sentry
.sentryclirc

# Lighthouse
.lighthouseci/

# ==============================================================================
# Package Manager Artifacts
# ==============================================================================

# npm
package-lock.json
npm-shrinkwrap.json

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
yarn.lock

# pnpm
pnpm-lock.yaml
.pnpm-store/

# ==============================================================================
# Optional: Uncomment if needed
# ==============================================================================

# ESLint cache
# .eslintcache

# Prettier cache
# .prettiercache

# Turborepo cache
# .turbo

# Storybook
# storybook-static/
# .storybook/

# Generated files (uncomment if you generate code)
# generated/
# __generated__/
