---
import { rawReadAll } from '../../lib/reader';
import DocLayout from '../../layouts/DocLayout.astro';

const items = rawReadAll('capabilities').filter((r) => r.frontmatter.id);

const sidebar = [
  { title: 'Navigation', links: [{ label: 'All Capabilities', href: '/capabilities' }] },
  {
    title: 'Capabilities',
    links: items.map((i) => ({
      label: `${i.frontmatter.id}: ${i.frontmatter.title ?? i.slug}`,
      href: `/capabilities/${i.slug}`,
    })),
  },
];
---

<DocLayout title="Capabilities" sidebar={sidebar}>
  <h1>Capabilities</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Cross-cutting system capabilities and their implementation status.
  </p>
  <div class="card-grid">
    {items.map((item) => {
      const statusColor = item.frontmatter.status === 'stable' ? 'green' : 'yellow';
      return (
        <div class="card">
          <a href={`/capabilities/${item.slug}`}>
            <div class="card__title">{item.frontmatter.id}: {item.frontmatter.title ?? item.slug}</div>
            <div class="card__meta">
              <span class={`badge badge--${statusColor}`}>{item.frontmatter.status}</span>
              {item.frontmatter.category && <span class="badge badge--blue">{item.frontmatter.category}</span>}
            </div>
          </a>
        </div>
      );
    })}
  </div>
</DocLayout>
