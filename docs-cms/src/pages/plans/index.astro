---
import { rawReadAll } from '../../lib/reader';
import DocLayout from '../../layouts/DocLayout.astro';

const formatSlug = (slug: string) =>
  slug.replace(/^\d+-/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

const items = rawReadAll('plans');

const sidebar = [
  { title: 'Navigation', links: [{ label: 'All Plans', href: '/plans' }] },
  {
    title: 'Plans',
    links: items.map((i) => ({
      label: i.frontmatter.title ?? formatSlug(i.slug),
      href: `/plans/${i.slug}`,
    })),
  },
];
---

<DocLayout title="Implementation Plans" sidebar={sidebar}>
  <h1>Implementation Plans</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Detailed implementation plans and design documents.
  </p>
  <div class="card-grid">
    {items.map((item) => (
      <div class="card">
        <a href={`/plans/${item.slug}`}>
          <div class="card__title">{item.frontmatter.title ?? formatSlug(item.slug)}</div>
        </a>
      </div>
    ))}
  </div>
</DocLayout>
