---
import { rawReadAll } from '../../lib/reader';
import DocLayout from '../../layouts/DocLayout.astro';

const roads = rawReadAll('roads').filter((r) => r.frontmatter.id);

const phaseNames: Record<number, string> = {
  0: 'Phase 0: Foundation',
  1: 'Phase 1: Bot Identity',
  2: 'Phase 2: Token & Promise',
  3: 'Phase 3: Settlement',
};

type RoadEntry = { slug: string; frontmatter: Record<string, any>; content: string };
const byPhase = new Map<number, RoadEntry[]>();
for (const road of roads) {
  const phase = road.frontmatter.phase ?? 0;
  if (!byPhase.has(phase)) byPhase.set(phase, []);
  byPhase.get(phase)!.push(road);
}

const sidebar = Array.from(byPhase.entries())
  .sort(([a], [b]) => a - b)
  .map(([phase, items]) => ({
    title: phaseNames[phase] ?? `Phase ${phase}`,
    links: items.map((r) => ({
      label: `${r.frontmatter.id}: ${r.frontmatter.title}`,
      href: `/roads/${r.slug}`,
    })),
  }));

sidebar.unshift({ title: 'Navigation', links: [{ label: 'All Roadmap Items', href: '/roads' }] });
---

<DocLayout title="Roadmap Items" sidebar={sidebar}>
  <h1>Roadmap Items</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Project milestones organized by delivery phase.
  </p>

  {Array.from(byPhase.entries())
    .sort(([a], [b]) => a - b)
    .map(([phase, items]) => (
      <div style="margin-bottom: 2rem;">
        <h2>{phaseNames[phase] ?? `Phase ${phase}`}</h2>
        <div class="card-grid">
          {items.map((road) => {
            const statusColor =
              road.frontmatter.status === 'complete' ? 'green' :
              road.frontmatter.status === 'in-progress' ? 'yellow' : 'gray';
            const prioColor =
              road.frontmatter.priority === 'High' ? 'red' :
              road.frontmatter.priority === 'Medium' ? 'yellow' : 'blue';
            return (
              <div class="card">
                <a href={`/roads/${road.slug}`}>
                  <div class="card__title">{road.frontmatter.id}: {road.frontmatter.title}</div>
                  <div class="card__meta">
                    <span class={`badge badge--${statusColor}`}>{road.frontmatter.status}</span>
                    <span class={`badge badge--${prioColor}`}>{road.frontmatter.priority}</span>
                  </div>
                </a>
              </div>
            );
          })}
        </div>
      </div>
    ))}
</DocLayout>
