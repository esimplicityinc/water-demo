---
import { rawReadAll } from '../lib/reader';
import BaseLayout from '../layouts/BaseLayout.astro';

const adrs = rawReadAll('adrs');
const roads = rawReadAll('roads');
const changes = rawReadAll('changes');
const nfrs = rawReadAll('nfrs');
const bdd = rawReadAll('bdd');
const ddd = rawReadAll('ddd');
const personas = rawReadAll('personas');
const userStories = rawReadAll('userStories');
const capabilities = rawReadAll('capabilities');
const plans = rawReadAll('plans');
const agents = rawReadAll('agents');

const sections = [
  { title: 'Roadmap Items', href: '/roads', count: roads.length, desc: 'Track project milestones, phases, and delivery status' },
  { title: 'Architecture Decision Records', href: '/adr', count: adrs.length, desc: 'Key architectural decisions and their rationale' },
  { title: 'Change Records', href: '/changes', count: changes.length, desc: 'Auditable change history with compliance signatures' },
  { title: 'Non-Functional Requirements', href: '/nfr', count: nfrs.length, desc: 'Performance, security, reliability, and accessibility standards' },
  { title: 'User Stories', href: '/user-stories', count: userStories.length, desc: 'User-facing requirements tied to personas and capabilities' },
  { title: 'Capabilities', href: '/capabilities', count: capabilities.length, desc: 'Cross-cutting system capabilities and their status' },
  { title: 'Personas', href: '/personas', count: personas.length, desc: 'User and bot personas that interact with the system' },
  { title: 'BDD Documentation', href: '/bdd', count: bdd.length, desc: 'Behavior-Driven Development methodology and guides' },
  { title: 'DDD Documentation', href: '/ddd', count: ddd.length, desc: 'Domain-Driven Design model, contexts, and patterns' },
  { title: 'Agent Documentation', href: '/agents', count: agents.length, desc: 'Multi-agent system architecture and coordination' },
  { title: 'Implementation Plans', href: '/plans', count: plans.length, desc: 'Detailed implementation plans and design documents' },
];
---

<BaseLayout title="Home">
  <main style="flex: 1;">
    {/* Hero */}
    <div class="home-hero">
      <h1>AquaTrack Documentation</h1>
      <p>Municipal Water Infrastructure Management System &mdash; browse docs or edit directly in the browser via Keystatic CMS.</p>
      <div class="home-hero__actions">
        <a href="/ddd" class="btn-hero btn-hero--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
          Explore DDD
        </a>
        <a href="/roads" class="btn-hero btn-hero--secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
          View Roadmap
        </a>
        <a href="/bdd" class="btn-hero btn-hero--secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          BDD Workflow
        </a>
      </div>
    </div>

    {/* Feature cards */}
    <div class="home-features">
      <div class="home-feature">
        <div class="home-feature__icon home-feature__icon--blue">
          <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
            <path d="M16 2C16 2 6 14 6 20a10 10 0 0020 0C26 14 16 2 16 2z" fill="currentColor" opacity="0.2"/>
            <path d="M16 2C16 2 6 14 6 20a10 10 0 0020 0C26 14 16 2 16 2z" fill="none" stroke="currentColor" stroke-width="1.5"/>
            <path d="M11 22h10M13 26h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Water Usage Tracking</h3>
        <p>Real-time monitoring of water consumption, anomaly detection, and automated alerts for residential and commercial customers.</p>
      </div>
      <div class="home-feature">
        <div class="home-feature__icon home-feature__icon--purple">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1.5"/>
            <rect x="14" y="3" width="7" height="7" rx="1.5"/>
            <rect x="3" y="14" width="7" height="7" rx="1.5"/>
            <rect x="14" y="14" width="7" height="7" rx="1.5"/>
            <path d="M10 6.5h4M6.5 10v4M17.5 10v4M10 17.5h4" stroke-dasharray="2 2"/>
          </svg>
        </div>
        <h3>DDD Architecture</h3>
        <p>Clean hexagonal architecture with bounded contexts, aggregates, value objects, and domain events. Fully documented domain model.</p>
      </div>
      <div class="home-feature">
        <div class="home-feature__icon home-feature__icon--green">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M9 11l3 3L22 4"/>
            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            <path d="M7 12l2 2" stroke-dasharray="2 2"/>
          </svg>
        </div>
        <h3>BDD-Driven Development</h3>
        <p>Behavior-Driven Development with Gherkin scenarios, automated test execution, and comprehensive feature coverage tracking.</p>
      </div>
    </div>

    {/* Section cards */}
    <div class="home-sections">
      {sections.map((section) => (
        <a href={section.href} class="home-section-card">
          <div class="home-section-card__title">{section.title}</div>
          <div class="home-section-card__desc">{section.desc}</div>
          <div class="home-section-card__count">{section.count} items</div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .home-hero__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.15s;
    text-decoration: none;
  }

  .btn-hero:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-hero--primary {
    background: var(--color-primary-dim);
    color: white;
  }

  .btn-hero--primary:hover {
    background: var(--color-primary);
  }

  .btn-hero--secondary {
    background: var(--color-bg-tertiary);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-hero--secondary:hover {
    border-color: var(--color-primary-dim);
    color: var(--color-primary);
  }

  /* Feature cards */
  .home-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto 2rem;
    padding: 0 1rem;
  }

  .home-feature {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
    text-align: center;
    transition: border-color 0.15s, transform 0.15s;
  }

  .home-feature:hover {
    border-color: var(--color-primary-dim);
    transform: translateY(-2px);
  }

  .home-feature__icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }

  .home-feature__icon--blue {
    background: rgba(56, 189, 248, 0.1);
    color: var(--color-primary);
  }

  .home-feature__icon--purple {
    background: rgba(167, 139, 250, 0.1);
    color: var(--color-accent-purple);
  }

  .home-feature__icon--green {
    background: rgba(74, 222, 128, 0.1);
    color: var(--color-accent-green);
  }

  .home-feature h3 {
    font-size: 1.1rem;
    color: var(--color-text-heading);
    margin: 0 0 0.5rem;
  }

  .home-feature p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .home-features {
      grid-template-columns: 1fr;
    }
  }
</style>
