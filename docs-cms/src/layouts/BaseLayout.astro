    <!-- Search overlay -->
    <div id="search-overlay" class="search-overlay" hidden>
      <div class="search-modal">
        <div class="search-modal__header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input id="search-input" type="text" placeholder="Search documentation..." autocomplete="off" />
          <kbd>Esc</kbd>
        </div>
        <div id="search-results" class="search-modal__results"></div>
        <div class="search-modal__footer">
          <span>Navigate with <kbd>&uarr;</kbd><kbd>&darr;</kbd></span>
          <span>Open with <kbd>Enter</kbd></span>
        </div>
      </div>
    </div>
    <script is:inline define:vars={{ searchItems }}>
      // === Theme toggle ===
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'light');
        if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
        const hlLink = document.querySelector('link[href*="highlight.js"]');
        if (hlLink && theme === 'light') hlLink.href = hlLink.href.replace('github-dark', 'github');

        document.addEventListener('DOMContentLoaded', () => {
          const btn = document.getElementById('theme-toggle');
          if (!btn) return;
          btn.addEventListener('click', () => {
            const isLight = document.documentElement.getAttribute('data-theme') === 'light';
            const next = isLight ? 'dark' : 'light';
            if (next === 'light') document.documentElement.setAttribute('data-theme', 'light');
            else document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('theme', next);
            const hl = document.querySelector('link[href*="highlight.js"]');
            if (hl) {
              hl.href = next === 'light'
                ? hl.href.replace('github-dark', 'github')
                : hl.href.replace(/github\.min/, 'github-dark.min');
            }
          });
        });
      })();

      // === Search ===
      (function() {
        const index = searchItems;
        let selectedIdx = -1;

        function openSearch() {
          const overlay = document.getElementById('search-overlay');
          const input = document.getElementById('search-input');
          overlay.hidden = false;
          input.value = '';
          input.focus();
          renderResults('');
          selectedIdx = -1;
        }

        function closeSearch() {
          document.getElementById('search-overlay').hidden = true;
        }

        function renderResults(query) {
          const container = document.getElementById('search-results');
          const q = query.toLowerCase().trim();
          let filtered = index;
          if (q) {
            filtered = index.filter(item =>
              item.title.toLowerCase().includes(q) || item.category.toLowerCase().includes(q)
            );
          }
          const shown = filtered.slice(0, 20);
          if (shown.length === 0) {
            container.innerHTML = '<div class="search-modal__empty">No results found</div>';
            return;
          }
          container.innerHTML = shown.map((item, i) =>
            '<a class="search-result' + (i === selectedIdx ? ' search-result--active' : '') + '" href="' + item.href + '">' +
              '<span class="search-result__title">' + escapeHtml(item.title) + '</span>' +
              '<span class="search-result__category">' + escapeHtml(item.category) + '</span>' +
            '</a>'
          ).join('');
        }

        function escapeHtml(s) {
          return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }

        function updateActive() {
          const items = document.querySelectorAll('.search-result');
          items.forEach((el, i) => el.classList.toggle('search-result--active', i === selectedIdx));
          if (items[selectedIdx]) items[selectedIdx].scrollIntoView({ block: 'nearest' });
        }

        document.addEventListener('DOMContentLoaded', () => {
          const trigger = document.getElementById('search-trigger');
          const overlay = document.getElementById('search-overlay');
          const input = document.getElementById('search-input');

          trigger.addEventListener('click', openSearch);
          overlay.addEventListener('click', (e) => { if (e.target === overlay) closeSearch(); });

          input.addEventListener('input', () => {
            selectedIdx = -1;
            renderResults(input.value);
          });

          input.addEventListener('keydown', (e) => {
            const items = document.querySelectorAll('.search-result');
            if (e.key === 'ArrowDown') { e.preventDefault(); selectedIdx = Math.min(selectedIdx + 1, items.length - 1); updateActive(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); selectedIdx = Math.max(selectedIdx - 1, 0); updateActive(); }
            else if (e.key === 'Enter' && items[selectedIdx]) { e.preventDefault(); items[selectedIdx].click(); }
            else if (e.key === 'Escape') closeSearch();
          });

          document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
            if (e.key === 'Escape' && !overlay.hidden) closeSearch();
          });
        });
      })();
      // === Collapsible sidebar sections ===
      (function() {
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('[data-sidebar-toggle]').forEach(btn => {
            btn.addEventListener('click', () => {
              const section = btn.closest('[data-sidebar-section]');
              const isCollapsed = section.classList.toggle('collapsed');
              btn.setAttribute('aria-expanded', String(!isCollapsed));
            });
          });

          // Auto-expand section containing the active link, collapse others with many items
          const sections = document.querySelectorAll('[data-sidebar-section]');
          sections.forEach(section => {
            const hasActive = section.querySelector('.active');
            const links = section.querySelectorAll('[data-sidebar-list] li');
            const title = section.querySelector('[data-sidebar-toggle] span');
            if (!hasActive && links.length > 10 && title && title.textContent.trim() !== 'Navigation') {
              section.classList.add('collapsed');
              section.querySelector('[data-sidebar-toggle]').setAttribute('aria-expanded', 'false');
            }
          });
        });
      })();

      // === Mobile menu ===
      (function() {
        document.addEventListener('DOMContentLoaded', () => {
          const btn = document.getElementById('mobile-menu-btn');
          const backdrop = document.getElementById('mobile-backdrop');
          if (!btn || !backdrop) return;

          function toggle() {
            const sidebar = document.querySelector('.site-sidebar');
            if (!sidebar) return;
            const isOpen = sidebar.classList.toggle('mobile-open');
            backdrop.classList.toggle('active', isOpen);
          }

          btn.addEventListener('click', toggle);
          backdrop.addEventListener('click', toggle);
        });
      })();

      // === Scroll to top ===
      (function() {
        const btn = document.getElementById('scroll-top');
        if (!btn) return;
        window.addEventListener('scroll', () => {
          btn.classList.toggle('visible', window.scrollY > 400);
        }, { passive: true });
        btn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
  </body>
