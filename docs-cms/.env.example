# Keystatic CMS - Environment Variables
# =======================================

# Storage mode: 'local' for development, 'github' for production
# When unset, defaults to 'local'
KEYSTATIC_STORAGE_KIND=local

# GitHub Storage Configuration (required when KEYSTATIC_STORAGE_KIND=github)
# Create a GitHub OAuth App: https://github.com/settings/developers
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# A random secret used to sign tokens (generate with: openssl rand -hex 32)
KEYSTATIC_SECRET=

# Your GitHub App slug (the URL-friendly name)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Repository details
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
